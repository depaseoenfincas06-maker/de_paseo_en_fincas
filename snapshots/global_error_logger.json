  "nodes": [
    {
      "parameters": {},
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [
        0,
        0
      ],
      "id": "et-error-trigger-aaaa-bbbb-cccc-dddd00000001",
      "name": "On error in any workflow"
    },
    {
      "parameters": {
        "jsCode": "// n8n Error Trigger payload shape:\n//   { execution: { id, url, mode, error, lastNodeExecuted, executionContext },\n//     workflow:  { id, name } }\nconst j = $json || {};\nconst exec = j.execution || {};\nconst wf = j.workflow || {};\nconst err = exec.error || j.error || {};\nconst compact = (v) => (v === undefined || v === null) ? '' : String(v);\nconst safeJson = (v) => { try { return JSON.stringify(v); } catch (e) { return String(v); } };\n\nreturn [{\n  json: {\n    workflow_id: compact(wf.id),\n    workflow_name: compact(wf.name),\n    execution_id: compact(exec.id),\n    execution_url: compact(exec.url),\n    node_name: compact(exec.lastNodeExecuted || (err.node && err.node.name) || j.lastNodeExecuted),\n    error_type: compact(err.name || err.errorCode || err.level || 'error'),\n    error_message: compact(err.message || err.description || ''),\n    error_stack: compact(err.stack || err.description || '').slice(0, 4000),\n    last_node_input: (function() {\n      const ctx = err.context || {};\n      const trig = (exec.executionContext && exec.executionContext.triggerNode) || {};\n      return safeJson({ trigger: trig, mode: exec.mode || '', err_ctx: ctx }).slice(0, 1000);\n    })(),\n  },\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        0
      ],
      "id": "et-format-row-aaaa-bbbb-cccc-dddd00000002",
      "name": "Format error row"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://script.google.com/macros/s/AKfycbzP5gPvB7z3p2uZdvyUetTbXom6EyWprQqH1DVhTxMVCsxk5aP8lgiErER4eSiYFLUQKg/exec",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "options": {
          "timeout": 15000,
          "redirect": {
            "redirect": {
              "followRedirects": true
            }
          },
          "response": {
            "response": {
              "responseFormat": "json",
              "neverError": true
            }
          }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        480,
        0
      ],
      "id": "et-post-sheet-aaaa-bbbb-cccc-dddd00000003",
      "name": "POST to error log sheet"
    }
  ],
