{
  "version": 2,
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/simulator",
      "destination": "/api"
    },
    {
      "source": "/monitoring",
      "destination": "/api"
    },
    {
      "source": "/settings",
      "destination": "/api"
    }
  ]
}
